# CELL 1 - Import
import pandas as pd
import numpy as np
import yfinance as yf

pd.set_option("display.max_columns", None)


# CELL 2 - Ambil OHLC GC=F dari yfinance
# Ambil mulai akhir 2024 supaya data 2025 punya target y dan lag yang cukup untuk backtest nanti

ticker = yf.Ticker("GC=F")

hist = ticker.history(
    start="2024-10-01",
    end=None,
    interval="1wk"
)

ohlc = (
    hist[["Open", "High", "Low", "Close"]]
    .dropna()
    .sort_index()
    .reset_index()
)

ohlc.columns = ["date", "open", "high", "low", "close"]
ohlc["date"] = pd.to_datetime(ohlc["date"]).dt.tz_localize(None).dt.normalize()

ohlc.head(), ohlc.tail(), ohlc.shape




# CELL - Ambil FFR dan NFP dari FRED API

import os
import requests
import pandas as pd

FRED_API_KEY = os.environ.get("FRED_API_KEY")
if not FRED_API_KEY:
    raise ValueError("FRED_API_KEY belum diset di environment")

def get_fred_series(series_id, start_date="2024-01-01", end_date=None):
    url = "https://api.stlouisfed.org/fred/series/observations"
    
    params = {
        "series_id": series_id,
        "api_key": FRED_API_KEY,
        "file_type": "json",
        "observation_start": start_date,
    }
    
    if end_date is not None:
        params["observation_end"] = end_date
    
    r = requests.get(url, params=params, timeout=60)
    r.raise_for_status()
    
    data = r.json()["observations"]
    
    df = pd.DataFrame(data)
    df = df[["date", "value"]].copy()
    df["date"] = pd.to_datetime(df["date"])
    df["value"] = pd.to_numeric(df["value"], errors="coerce")
    df = df.dropna().sort_values("date").reset_index(drop=True)
    
    return df


# CELL - Download FFR dan NFP


ffr_raw = get_fred_series("DFEDTARU", start_date="2024-01-01")
payems_raw = get_fred_series("PAYEMS", start_date="2024-01-01")

ffr = ffr_raw.rename(columns={"value": "ffr"})

payems = payems_raw.rename(columns={"value": "payems"})
payems["nfp"] = payems["payems"].diff()

macro = pd.merge(
    ffr,
    payems[["date", "nfp"]],
    on="date",
    how="outer"
)

macro = macro.sort_values("date").reset_index(drop=True)
macro[["ffr", "nfp"]] = macro[["ffr", "nfp"]].ffill()
macro = macro.dropna(subset=["ffr", "nfp"]).reset_index(drop=True)

macro.tail()


# CELL 4 - Gabungkan OHLC mingguan dengan macro bulanan
# merge_asof artinya setiap minggu pakai data macro terakhir yang sudah tersedia

df = pd.merge_asof(
    ohlc.sort_values("date"),
    macro.sort_values("date"),
    on="date",
    direction="backward"
)

df = df.dropna(subset=["ffr", "nfp"]).reset_index(drop=True)

df


# CELL 5 - Buat y dan arah

df["y"] = df["close"].shift(-1)

df["arah"] = np.where(
    df["y"] > df["close"],
    "Naik",
    "Turun"
)

df = df.dropna(subset=["y"]).reset_index(drop=True)

df_2025 = df[df["date"] >= "2025-01-01"].copy()

df_2025 = df_2025[
    ["date", "open", "high", "low", "close", "ffr", "nfp", "y", "arah"]
]

df_2025["date"] = pd.to_datetime(df_2025["date"]).dt.strftime("%Y-%m-%d")

df_2025 = df_2025.round({
    "open": 2,
    "high": 2,
    "low": 2,
    "close": 2,
    "ffr": 2,
    "nfp": 0,
    "y": 2
})

df_2025


df_2025.to_csv("test_2025_baru.csv", index=False)

print(df_2025.shape)
df_2025.tail()
